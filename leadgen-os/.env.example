# LLM Provider
# "deepseek" (default) or "anthropic"
LLM_PROVIDER=deepseek

# DeepSeek API (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Anthropic API (optional, for outreach quality)
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_IDS=123456789

# Email (Resend API veya msmtp)
EMAIL_PROVIDER=msmtp
RESEND_API_KEY=re_xxx
EMAIL_FROM="AmareNL <info@amarenl.com>"

# Project root (otomatik algılanır)
PROJECT_ROOT=/Users/ark/projects/amarenl.com/leadgen-os

# Limits
MAX_EMAILS_PER_DAY=20
MAX_LEADS_PER_DISCOVERY=30
