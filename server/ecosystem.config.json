{
  "apps": [
    {
      "name": "amarenl-orchestrator",
      "script": "./node_modules/.bin/tsx",
      "args": "index.ts",
      "cwd": "/opt/AmareNL.com/server",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 30000,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "production"
      },
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "/opt/AmareNL.com/logs/pm2-error.log",
      "out_file": "/opt/AmareNL.com/logs/pm2-out.log",
      "merge_logs": true
    }
  ]
}
