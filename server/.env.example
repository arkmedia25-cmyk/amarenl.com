# =============================================
# AmareNL Orchestrator — Environment Variables
# =============================================

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot
# 1. @BotFather ile bot oluştur: https://t.me/BotFather
# 2. Token'ı buraya yaz:
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# 3. Bot'a mesaj at, sonra şu komutla chat ID'ni al:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. Yetkili chat ID'lerini virgülle ayırarak yaz:
TELEGRAM_ADMIN_CHAT_IDS=123456789

# Proje yolu (bu repo'nun mutlak yolu)
PROJECT_ROOT=/Users/ark/Documents/AmareNL.com

# Opsiyonel: Vercel deploy hook
# VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...

# Opsiyonel: GA4 Property ID (traffic-monitor için)
# GA4_PROPERTY_ID=GT-MKTPDM2M
